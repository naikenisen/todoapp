{
  "name": "isenapp",
  "version": "1.0.0",
  "description": "ISENAPP — Client email Electron avec gestion de tâches, autoconfig email et visualisation Graph",
  "author": {
    "name": "Isen Naiken",
    "email": "isen.naiken@nexomedis.com"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "icons:generate": "mkdir -p build && npx --yes icon-gen -i assets/logo.svg -o build --ico --icns && mv -f build/app.icns build/icon.icns && mv -f build/app.ico build/icon.ico && rsvg-convert -w 512 -h 512 assets/logo.svg -o build/icon.png",
    "build": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --mac --win",
    "build:dir": "electron-builder --linux --dir"
  },
  "build": {
    "appId": "com.nexomedis.isenapp",
    "productName": "ISENAPP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "data/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/renderer",
        "to": "src/renderer"
      },
      {
        "from": "assets/logo.svg",
        "to": "assets/logo.svg"
      },
      {
        "from": "src/backend",
        "to": "src/backend"
      },
      {
        "from": "data/data.json",
        "to": "data/data.json"
      },
      {
        "from": "data/contacts_complets_v2.csv",
        "to": "data/contacts_complets_v2.csv"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3"
  }
}
