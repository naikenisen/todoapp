# Neo4j connection settings
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Google Gemini API key (used for RAG answer generation)
GEMINI_API_KEY=AIza...

# Optional: primary Gemini text model (default: gemma-3-27b-it)
# Use a model with higher quota in your account.
# GEMINI_MODEL=gemma-3-27b-it

# Optional: fallback models if primary is rate-limited/unavailable (comma-separated)
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash

# Optional: embedding model (default: intfloat/multilingual-e5-base)
# If you change this value, re-run Neo4j sync/reingestion to rebuild embeddings.
# EMBEDDING_MODEL=intfloat/multilingual-e5-base
